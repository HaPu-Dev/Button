-- Create section helper
local function createButton(text, size)
	local section = Instance.new("Frame")
	section.Size = UDim2.new(0, 40, 1, 0)
	section.BackgroundTransparency = 1
	section.Parent = mainFrame

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	btn.BorderSizePixel = 0
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = size or 12
	btn.Font = Enum.Font.GothamBold
	btn.AutoButtonColor = false
	btn.Parent = section

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = btn

	btn.MouseEnter:Connect(function()
		if not btn:GetAttribute("Holding") then
			btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
		end
	end)

	btn.MouseLeave:Connect(function()
		if not btn:GetAttribute("Holding") then
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		end
	end)

	return btn
end

-- Buttons
local nButton = createButton("🎒", 14)
local hButton = createButton("📖", 14)
local ueqButton = createButton("⚡", 14)

ueqButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)

-- Toggle tool helper
local function toggleTool(toolName)
	local char = player.Character
	if not char then return end
	
	local backpack = player:WaitForChild("Backpack")
	local tool = backpack:FindFirstChild(toolName)
	local equipped = char:FindFirstChild(toolName)
	
	if equipped then
		equipped.Parent = backpack
	elseif tool then
		tool.Parent = char
	end
end

-- Buttons
nButton.Activated:Connect(function()
	toggleTool("Equipment Bag")
end)

hButton.Activated:Connect(function()
	toggleTool("Bestiary")
end)

-- Unequip all
local function unequipAll()
	local char = player.Character
	local backpack = player:WaitForChild("Backpack")
	if not char then return end
	
	for _, tool in ipairs(char:GetChildren()) do
		if tool:IsA("Tool") then
			tool.Parent = backpack
		end
	end
end

-- HOLD logic
local holding = false
local holdThread

ueqButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch 
	or input.UserInputType == Enum.UserInputType.MouseButton1 then
		
		holding = true
		ueqButton:SetAttribute("Holding", true)
		ueqButton.BackgroundColor3 = Color3.fromRGB(80, 30, 30)

		holdThread = task.spawn(function()
			while holding do
				unequipAll()
				task.wait(0.1)
			end
		end)
	end
end)

ueqButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch 
	or input.UserInputType == Enum.UserInputType.MouseButton1 then
		
		holding = false
		ueqButton:SetAttribute("Holding", false)
		ueqButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)

		if holdThread then
			task.cancel(holdThread)
			holdThread = nil
		end
	end
end)

-- Toggle GUI
userInputService.InputBegan:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.RightBracket then
		mainFrame.Visible = not mainFrame.Visible
	end
end)

print("Equipment Buttons Loaded (Fisch Only)")

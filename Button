-- UEQ button functionality (Unequip all tools on HOLD)
local function unequipAll()
	local char = player.Character
	local backpack = player:WaitForChild("Backpack")
	if not char then return end
	
	for _, tool in ipairs(char:GetChildren()) do
		if tool:IsA("Tool") then
			tool.Parent = backpack
		end
	end
end

-- Hold logic
local holding = false
local holdThread = nil

ueqButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch 
	or input.UserInputType == Enum.UserInputType.MouseButton1 then
		
		holding = true
		
		-- Change appearance while holding
		ueqButton.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
		
		holdThread = task.spawn(function()
			while holding do
				unequipAll()
				task.wait(0.1)
			end
		end)
	end
end)

ueqButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch 
	or input.UserInputType == Enum.UserInputType.MouseButton1 then
		
		holding = false
		
		-- Restore appearance
		ueqButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
		
		if holdThread then
			task.cancel(holdThread)
			holdThread = nil
		end
	end
end)

-- Toggle buttons with ']' key
userInputService.InputBegan:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.RightBracket then
		buttonsFrame.Visible = not buttonsFrame.Visible
	end
end)

